platform :android do
  lane :deploy do
    testing = ENV.fetch("DEPLOY_ENV", "testing") == "testing"
    root = File.expand_path("..", __dir__)

    File.write(File.join(root, "android/key.properties"), [
      "storePassword=#{ENV.fetch("KEYSTORE_PASSWORD")}",
      "keyPassword=#{ENV.fetch("KEY_PASSWORD")}",
      "keyAlias=#{ENV.fetch("KEY_ALIAS")}",
      "storeFile=#{ENV.fetch("KEYSTORE_PATH")}",
    ].join("\n"))

    sh("flutter", "build", "appbundle", "--release", chdir: root)

    upload_to_play_store(
      track: testing ? "internal" : "production",
      aab: File.join(root, "build/app/outputs/bundle/release/app-release.aab"),
      json_key_data: ENV.fetch("PLAY_STORE_JSON_KEY"),
      package_name: "com.linklado.tuklado.tuklado_flutter",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end

platform :ios do
  lane :deploy do
    testing = ENV.fetch("DEPLOY_ENV", "testing") == "testing"

    api_key = app_store_connect_api_key(
      key_id: "4WR9XHCU43",
      issuer_id: "f7a19456-7a78-4c83-a050-8f8957b75fbb",
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )

    match(
      type: "appstore",
      app_identifier: ["com.linklado.linklado", "com.linklado.linklado.Linklado"],
      api_key: api_key,
      readonly: true,
      git_url: "https://github.com/julianodportela/certificates",
      git_branch: "main",
      team_id: "3W93D6R57D",
    )

    root = File.expand_path("..", __dir__)
    xcodeproj = File.join(root, "ios/Runner.xcodeproj")

    {
      "Runner"   => ["com.linklado.linklado",          "match AppStore com.linklado.linklado"],
      "Linklado" => ["com.linklado.linklado.Linklado", "match AppStore com.linklado.linklado.Linklado"],
    }.each do |target, (bundle_id, profile)|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: xcodeproj,
        team_id: "3W93D6R57D",
        targets: target,
        code_sign_identity: "iPhone Distribution",
        profile_name: profile,
        bundle_identifier: bundle_id,
        build_configurations: ["Release"],
      )
    end

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "build/ios/ipa",
      output_name: "Linklado.ipa",
      export_options: {
        provisioningProfiles: {
          "com.linklado.linklado" => "match AppStore com.linklado.linklado",
          "com.linklado.linklado.Linklado" => "match AppStore com.linklado.linklado.Linklado",
        }
      }
    )

    if testing
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
      )
    else
      upload_to_app_store(
        api_key: api_key,
        skip_metadata: true,
        skip_screenshots: true,
        submit_for_review: false,
        precheck_include_in_app_purchases: false,
        force: true,
      )
    end
  end
end
